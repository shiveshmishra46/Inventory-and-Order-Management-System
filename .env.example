# ─────────────────────────────────────────────────────────────────────────────
# Inventory & Order Management System — Environment Variables
# Copy this file to .env and fill in your values
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventory_db

# ─── Backend ──────────────────────────────────────────────────────────────────
# Full DSN for SQLAlchemy — host must match the docker-compose service name "db"
DATABASE_URL=postgresql://postgres:postgres@db:5432/inventory_db

# Port exposed by the backend container
PORT=8000

# URL used by the backend to configure CORS (comma-separate if needed)
FRONTEND_URL=http://localhost:3000

# ─── Frontend ─────────────────────────────────────────────────────────────────
# URL of the backend API (used at React build time)
REACT_APP_API_URL=http://localhost:8000

# Public URLs (fill in after deployment)
BACKEND_URL=http://localhost:8000
